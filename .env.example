# Spotify — Client Credentials (for music search, no user login required)
# Get these from https://developer.spotify.com → your app → Settings
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# OAuth redirect URI — must match what's registered in your auth provider
VITE_REDIRECT_URI=http://127.0.0.1:5173/
